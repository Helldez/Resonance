{
  "name": "resonance",
  "version": "0.1.0",
  "description": "Local-first P2P social network where posts are matched between peers by semantic similarity and answered by on-device AI. Built on the Tether QVAC SDK and Hyperswarm/Hypercore. Android (Expo + React Native) for the MVP.",
  "main": "index.ts",
  "license": "Apache-2.0",
  "author": "Helldez",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "prebuild": "npx expo prebuild",
    "typecheck": "tsc --noEmit",
    "test": "tsx scripts/test/inbox-admission.test.ts && tsx scripts/test/topics.test.ts",
    "calibrate": "node scripts/calibration/evaluate-embeddings.mjs",
    "build:bare": "node bare/build.mjs",
    "build:bare:desktop": "node bare/build-desktop.mjs",
    "desktop:peer": "tsx scripts/desktop/peer.ts",
    "web:export": "expo export -p web && node scripts/desktop/patch-web-html.mjs",
    "electron:dev": "electron electron/main.cjs",
    "app:dev": "npm run web:export && electron electron/main.cjs",
    "postinstall": "patch-package",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@noble/ed25519": "^2.2.3",
    "@noble/hashes": "^1.5.0",
    "@qvac/sdk": "^0.11.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "babel-preset-expo": "~54.0.10",
    "bare-abort-controller": "^1.1.1",
    "bare-buffer": "^3.6.0",
    "bare-crypto": "^1.13.4",
    "bare-dns": "^2.1.4",
    "bare-fetch": "^2.8.2",
    "bare-fs": "^4.7.0",
    "bare-http1": "^4.5.6",
    "bare-https": "^2.1.3",
    "bare-link": "^3.2.2",
    "bare-net": "^2.3.1",
    "bare-os": "^3.8.7",
    "bare-path": "^3.0.0",
    "bare-process": "^4.4.1",
    "bare-readline": "^1.3.1",
    "bare-rpc": "^1.2.0",
    "bare-runtime": "^1.28.4",
    "bare-stream": "^2.13.0",
    "bare-subprocess": "^6.0.0",
    "bare-tls": "^3.1.5",
    "bare-url": "^2.4.0",
    "bare-zlib": "^1.3.3",
    "buffer": "^6.0.3",
    "compact-encoding": "^2.19.2",
    "corestore": "^7.9.2",
    "events": "^3.3.0",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~17.0.0",
    "expo-device": "~8.0.0",
    "expo-file-system": "~19.0.21",
    "expo-linking": "~7.0.0",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "^55.0.18",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "hyperdb": "^4.22.3",
    "hyperdrive": "^13.3.2",
    "hyperswarm": "^4.17.0",
    "llm-splitter": "^0.2.0",
    "pear-pipe": "^1.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-bare-kit": "~0.11.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-paper": "^5.15.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.12.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.0",
    "tar-stream": "^3.2.0",
    "umap-js": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@qvac/cli": "^0.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.17",
    "@types/react": "~19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "better-sqlite3": "^11.7.0",
    "electron": "^33.4.11",
    "patch-package": "^8.0.1",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2"
  }
}
